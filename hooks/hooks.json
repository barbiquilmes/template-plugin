{
  "hooks": {
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d ${CLAUDE_PLUGIN_DATA}/venv || (uv venv ${CLAUDE_PLUGIN_DATA}/venv && uv pip install --python ${CLAUDE_PLUGIN_DATA}/venv/bin/python ${CLAUDE_PLUGIN_ROOT})"
          }
        ]
      }
    ]
  }
}
